{
  "name": "invinite-api-cli",
  "version": "0.1.17",
  "type": "module",
  "description": "CLI for the Invinite API",
  "homepage": "https://github.com/outraday-org/invinite-api-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/outraday-org/invinite-api-cli.git"
  },
  "bugs": {
    "url": "https://github.com/outraday-org/invinite-api-cli/issues"
  },
  "bin": {
    "invinite": "./dist/bin/invinite.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx bin/invinite.ts",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "publish:version": "npm version patch && export $(cat .env | xargs) && npm publish --access public"
  },
  "files": [
    "dist",
    "claude-plugin"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "enquirer": "^2.4.1",
    "ora": "^8.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^2.10.1",
    "@types/node": "^22.10.2",
    "eslint": "^9.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.1.8"
  }
}
